# Python
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Virtual environments
.venv/
venv/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Handoff orchestration state (ephemeral, not committed)
handoff-state.json
.handoff-state.tmp
.handoff-session.json

# User project artifacts (created by setup command or TUI, not part of this repo)
projects/
/.spike-output/
# Track .tagteam/legacy/ (Step B canonical pre-activation cycle source —
# fresh clones need it for cycle history reads) but ignore everything
# else under .tagteam/ (DB, transient sentinels, watcher state, etc.).
/.tagteam/*
!/.tagteam/legacy/
